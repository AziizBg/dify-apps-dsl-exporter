DIFY_ORIGIN=http://localhost
EMAIL=your-email@example.com
PASSWORD=your-password

# Folder used by both export.py and import.py.
DSL_FOLDER_PATH=./dsl

# Keep this false for team sharing. Set to true only when you intentionally
# need exported workflow environment variable values/secrets in the YAML.
DIFY_INCLUDE_SECRET=false

# --- Confluence tracker sync (src/sync_tracker.py) ---
# Confluence Cloud base URL, including the /wiki suffix.
CONFLUENCE_BASE_URL=https://your-site.atlassian.net/wiki
# Atlassian account email that owns the API token below.
CONFLUENCE_EMAIL=your-email@example.com
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_API_TOKEN=your-confluence-api-token
# Numeric id of the tracker page to keep in sync.
CONFLUENCE_PAGE_ID=407797761

# --- Slack notification (src/slack_notify.py) ---
# Incoming webhook URL for the channel that should receive the status message.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
